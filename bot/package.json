{
  "type": "module",
  "name": "@scheduletm/bot",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "npm run typecheck && vite build --watch",
    "build": "npm run typecheck && npm run test && vite build",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.9",
    "pg": "^8.20.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
